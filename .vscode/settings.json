{
    "cSpell.words": [
        "arraybuffer",
        "drawinga",
        "inputx",
        "inputy",
        "nidx",
        "ONNX",
        "onnxruntime",
        "outx",
        "outy",
        "paddleocr",
        "ppocrv",
        "sratio",
        "thresholded",
        "timestep"
    ],
    "js/ts.tsdk.path": "node_modules/typescript/lib",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
        "source.fixAll.biome": "explicit",
        "source.organizeImports.biome": "explicit"
    },
    "[typescript]": {
        "editor.defaultFormatter": "biomejs.biome"
    },
    "[typescriptreact]": {
        "editor.defaultFormatter": "biomejs.biome"
    },
    "[javascript]": {
        "editor.defaultFormatter": "biomejs.biome"
    },
    "[json]": {
        "editor.defaultFormatter": "biomejs.biome"
    },
    "[jsonc]": {
        "editor.defaultFormatter": "biomejs.biome"
    }
}

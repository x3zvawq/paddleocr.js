{
    "compilerOptions": {
        "allowImportingTsExtensions": true,
        "target": "esnext",
        "declaration": true,
        "sourceMap": true,
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "noEmit": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "erasableSyntaxOnly": true,
        "types": ["node"]
    },
    "exclude": ["node_modules", "dist"],
    "include": ["./src/**/*", "./test/**/*"]
}
